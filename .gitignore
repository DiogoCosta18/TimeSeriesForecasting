# Ignore everything by default. This repository is only for paper-facing
# result artifacts, not the training pipeline, raw data, notebooks, or machine
# setup files.
*

# Keep repository metadata/docs.
!.gitignore
!README.md

# Derived result summaries from the benchmark run.
!results/
results/*
!results/*.csv
!results/*.json
results/run_results.tar.gz
results/best_model_forecasts.csv
results/decomposition_deltas.csv
results/forecasts_joined.csv
results/metrics_by_series.csv
results/run_config.json
results/selected_series.csv
results/series_characteristics.csv
!results/run_20260525T112121/
results/run_20260525T112121/*
!results/run_20260525T112121/data_manifest.json
!results/run_20260525T112121/finetuning/
results/run_20260525T112121/finetuning/*
!results/run_20260525T112121/finetuning/finetune_manifest.parquet

# Paper analysis outputs: aggregate tables, export reports, and figures.
!results_week4/
results_week4/*
!results_week4/*.csv
!results_week4/*.md
results_week4/codebase_cleanup_manifest.csv
results_week4/codebase_cleanup_summary.md
results_week4/decomposition_delta_by_series.csv
results_week4/seasonality_group_index.csv
results_week4/family_mcm_top*_inputs.csv
results_week4/metric_recomputed_by_series.csv
!results_week4/*/
results_week4/*/*
!results_week4/*/*.csv
!results_week4/*/*.png
!results_week4/*/*.md
results_week4/_cache/
results_week4/**/_cache/
results_week4/**/decomposition_delta_by_series.csv
results_week4/**/metric_recomputed_by_series.csv
results_week4/**/family_mcm_top*_inputs.csv
results_week4/**/mcm_input_*.csv
results_week4/**/figure_export_report.csv

# Never publish local/runtime/private material.
.claude/
.time_series/
.jupyter_runtime/
